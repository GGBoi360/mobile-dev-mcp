{
  "name": "@ggboi360/mobile-dev-mcp",
  "version": "0.1.0",
  "description": "MCP server for mobile development with Claude - stream Metro logs, capture screenshots, monitor ADB",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mobile-dev-mcp": "./dist/index.js"
  },
  "files": [
    "dist/**/*",
    "LICENSE",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/GGBoi360/mobile-dev-mcp.git"
  },
  "homepage": "https://ggboi360.github.io/mobile-dev-mcp",
  "bugs": {
    "url": "https://github.com/GGBoi360/mobile-dev-mcp/issues"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "npm run build"
  },
  "keywords": [
    "claude",
    "mcp",
    "mobile-dev",
    "react-native",
    "expo",
    "android",
    "adb",
    "metro"
  ],
  "author": "GGBoi360",
  "license": "Elastic-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.17"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
